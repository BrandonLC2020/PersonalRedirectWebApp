{
    "name": "PersonalRedirectWebApp",
    "displayName": "Personal Redirect Web App",
    "expo": {
      "name": "Personal Redirect Web App",
      "slug": "personal-redirect-web-app",
      "version": "1.0.0",
      "orientation": "portrait",
      "icon": "./assets/icon.png",
      "userInterfaceStyle": "automatic",
      "splash": {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      },
      "updates": {
        "fallbackToCacheTimeout": 0
      },
      "assetBundlePatterns": [
        "**/*"
      ],
      "ios": {
        "supportsTablet": true,
        "bundleIdentifier": "com.yourname.personalredirectwebapp"
      },
      "android": {
        "adaptiveIcon": {
          "foregroundImage": "./assets/adaptive-icon.png",
          "backgroundColor": "#ffffff"
        },
        "package": "com.yourname.personalredirectwebapp"
      },
      "web": {
        "favicon": "./assets/favicon.png"
      },
      "extra": {
        "apiBaseUrl": "@NGROK_URL"
      }
    }
  }
  